{
  "name": "im-codex-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "reco": "./reco",
    "tool": "./reco"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "reco": "./reco",
    "tool": "node ./packages/ops-cli/src/cli.js",
    "start": "node ./packages/ops-cli/src/cli.js start",
    "stop": "node ./packages/ops-cli/src/cli.js stop",
    "restart": "node ./packages/ops-cli/src/cli.js restart",
    "status": "node ./packages/ops-cli/src/cli.js status",
    "doctor": "node ./packages/ops-cli/src/cli.js doctor",
    "test": "node --test packages/*/test/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test packages/*/test/*.test.js",
    "ci": "npm test"
  },
  "engines": {
    "node": ">=24"
  }
}
