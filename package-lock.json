{
  "name": "im-codex-tool",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "im-codex-tool",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@im-codex/core-runtime": {
      "resolved": "packages/core-runtime",
      "link": true
    },
    "node_modules/@im-codex/im-gateway": {
      "resolved": "packages/im-gateway",
      "link": true
    },
    "node_modules/@im-codex/ops-cli": {
      "resolved": "packages/ops-cli",
      "link": true
    },
    "node_modules/@im-codex/state-store": {
      "resolved": "packages/state-store",
      "link": true
    },
    "packages/core-runtime": {
      "name": "@im-codex/core-runtime",
      "version": "0.1.0"
    },
    "packages/im-gateway": {
      "name": "@im-codex/im-gateway",
      "version": "0.1.0"
    },
    "packages/ops-cli": {
      "name": "@im-codex/ops-cli",
      "version": "0.1.0",
      "bin": {
        "tool": "src/cli.js"
      }
    },
    "packages/state-store": {
      "name": "@im-codex/state-store",
      "version": "0.1.0"
    }
  }
}
